	@echo "Installing Ingress Nginx"
	helm upgrade \
		--install \
		--create-namespace \
		--namespace ingress-nginx \
		--wait \
		-f build/values/ingress-nginx.yml \
		ingress-nginx \
		ingress-nginx/ingress-nginx

harbor:
	@echo "Installing Harbor registry"
	helm upgrade \
		--install \
		--create-namespace \
		--namespace harbor \
		--wait \
		--version=1.16.2 \
		-f build/values/harbor.yml \
		harbor \
		harbor/harbor

registry:
	@echo "Installing unauthenticated registry"
	helm upgrade \
		--install \
		--create-namespace \
		--namespace registry \
		--wait \
		--set ingress.enabled=true \
		--set "ingress.hosts[0]=registry.$$($(KUBECTL) -n ingress-nginx get services ingress-nginx-controller -o jsonpath='{.status.loadBalancer.ingress[0].ip}').nip.io" \
		--set ingress.path="/" \
		--set persistence.enabled=true \
		--version=2.2.3 \
		registry \
		twuni/docker-registry

minio:
	@echo "Installing MinIO"
	helm upgrade \
		--install \
		--create-namespace \
		--namespace minio \
		--wait \
		-f build/values/minio.yml \
		minio \
		oci://registry-1.docker.io/cloudpirates/minio
	$(KUBECTL) -n minio exec -it $$($(KUBECTL) -n minio get pod -l app.kubernetes.io/name=minio -o jsonpath="{.items[0].metadata.name}") \
		-- sh -c 'mc alias set local http://localhost:9000 admin $(MINIO_PASSWORD) && mc mb local/lagoon-files && mc mb local/restores' || true

postgres:
	@echo "Installing PostgreSQL"
	helm upgrade \
		--install \
		--create-namespace \
		--namespace postgresql \
		--wait \
		--set auth.postgresPassword="$(POSTGRES_PASSWORD)" \
		postgresql \
		oci://registry-1.docker.io/cloudpirates/postgres

mariadb:
	@echo "Installing MariaDB"
	helm upgrade \
		--install \
		--create-namespace \
		--namespace mariadb \
		--wait \
		--set auth.rootPassword="$(MARIADB_PASSWORD)" \
		mariadb \
		oci://registry-1.docker.io/cloudpirates/mariadb


# Makefile for LagoonAtHome — Lagoon on k3s for homelabs
SHELL := /bin/bash
.ONESHELL:
.SHELLFLAGS := -eu -o pipefail -c
.DEFAULT_GOAL := all

# Load user configuration (generated by install.sh or copied from .env.example)
-include .env
export

export KUBECONFIG := $(HOME)/.kube/config
KUBECTL := kubectl

# Variables that must be set (either via .env or environment)
DOMAIN ?= $(NODE_IP).nip.io
CLUSTER_ISSUER ?= lagoon-issuer
TLS_MODE ?= selfsigned
ORG_NAME ?= lagoon
ADMIN_EMAIL ?= admin@example.com
ADMIN_PASSWORD ?= changeme
ADMIN_FIRST_NAME ?= Admin
ADMIN_LAST_NAME ?= User
SSH_KEY_PATH ?= $(HOME)/.ssh/id_ed25519
MINIO_PASSWORD ?= changeme
HARBOR_PASSWORD ?= changeme
POSTGRES_PASSWORD ?= changeme
MARIADB_PASSWORD ?= changeme
LAGOON_NETWORK_RANGE ?= 192.168.1.150-192.168.1.160
NODE_IP ?= 192.168.1.150
INSTALL_HARBOR ?= false
INSTALL_PROMETHEUS ?= false
INSTALL_POSTGRES ?= true
INSTALL_MARIADB ?= true
INSTALL_HEADLAMP ?= false

# Explicit list of variables for envsubst (avoids clobbering $$i, $$namespace, etc. in YAML)
ENVSUBST_VARS := '$${DOMAIN} $${CLUSTER_ISSUER} $${ADMIN_EMAIL} $${ADMIN_PASSWORD} \
	$${ORG_NAME} $${MINIO_PASSWORD} $${HARBOR_PASSWORD} $${POSTGRES_PASSWORD} \
	$${MARIADB_PASSWORD} $${ACME_EMAIL} $${CLOUDFLARE_API_TOKEN} $${NODE_IP} \
	$${LAGOON_NETWORK_RANGE} $${BASE_URL}'

# Backwards compat
BASE_URL := $(DOMAIN)

# OS detection
OS := $(shell uname -s | tr '[:upper:]' '[:lower:]')
ARCH := $(shell uname -m)
ifeq ($(ARCH),x86_64)
  ARCH := amd64
endif
ifeq ($(ARCH),aarch64)
  ARCH := arm64
endif

.PHONY: basic all core-dependencies extras generate-config \
	k3s system helm-repos helm metallb cert-manager gatekeeper ingress \
	harbor registry minio postgres mariadb prometheus headlamp \
	lagoon-core lagoon-remote lagoon-config post-install \
	build-deploy-tool push-local-build-image \
	clean-bdt clean-ssh nuke

# --- High-level targets ---
basic: generate-config core-dependencies lagoon-core lagoon-remote lagoon-config build-deploy-tool push-local-build-image

all: generate-config core-dependencies extras lagoon-core lagoon-remote lagoon-config

core-dependencies: k3s system helm-repos metallb cert-manager gatekeeper ingress registry minio

extras:
	@$(MAKE) _optional_harbor
	@$(MAKE) _optional_prometheus
	@$(MAKE) _optional_postgres
	@$(MAKE) _optional_mariadb
	@$(MAKE) _optional_headlamp

_optional_harbor:
	@if [ "$(INSTALL_HARBOR)" = "true" ]; then $(MAKE) harbor; fi

_optional_prometheus:
	@if [ "$(INSTALL_PROMETHEUS)" = "true" ]; then $(MAKE) prometheus; fi

_optional_postgres:
	@if [ "$(INSTALL_POSTGRES)" = "true" ]; then $(MAKE) postgres; fi

_optional_mariadb:
	@if [ "$(INSTALL_MARIADB)" = "true" ]; then $(MAKE) mariadb; fi

_optional_headlamp:
	@if [ "$(INSTALL_HEADLAMP)" = "true" ]; then $(MAKE) headlamp; fi

# --- Config generation ---
generate-config:
	@echo "Generating config from templates"
	mkdir -p build/config build/values generated/ssh-host-keys
	# Template config files
	for tpl in config/*.tpl; do \
		out="build/config/$$(basename "$${tpl%.tpl}")"; \
		envsubst $(ENVSUBST_VARS) < "$$tpl" > "$$out"; \
	done
	# Template values files
	for tpl in values/*.tpl; do \
		out="build/values/$$(basename "$${tpl%.tpl}")"; \
		envsubst $(ENVSUBST_VARS) < "$$tpl" > "$$out"; \
	done
	# Copy static config files
	for f in config/*.yml; do \
		cp "$$f" "build/config/$$(basename "$$f")"; \
	done
	# Copy static values files
	for f in values/*.yml; do \
		cp "$$f" "build/values/$$(basename "$$f")"; \
	done
	# Generate SSH host keys if not present
	@if [ ! -f generated/ssh-host-keys/ssh_host_rsa_key ]; then \
		echo "Generating SSH host keys"; \
		ssh-keygen -t rsa -b 4096 -f generated/ssh-host-keys/ssh_host_rsa_key -N "" -q; \
		ssh-keygen -t ecdsa -b 256 -f generated/ssh-host-keys/ssh_host_ecdsa_key -N "" -q; \
		ssh-keygen -t ed25519 -f generated/ssh-host-keys/ssh_host_ed25519_key -N "" -q; \
	fi
	# Generate SSH portal/token host key if not present
	@if [ ! -f generated/ssh-host-keys/ssh_portal_ed25519_key ]; then \
		echo "Generating SSH portal host keys"; \
		ssh-keygen -t ed25519 -f generated/ssh-host-keys/ssh_portal_ed25519_key -N "" -q; \
	fi

# --- Core system setup ---
k3s:
	@echo "Installing k3s"
	curl -sfL https://get.k3s.io | INSTALL_K3S_EXEC="server --disable=traefik --disable=servicelb --write-kubeconfig-mode 644" sh -
	sudo mkdir -p $$(dirname $(KUBECONFIG))
	sudo cp /etc/rancher/k3s/k3s.yaml $(KUBECONFIG)
	sudo chmod 644 $(KUBECONFIG)
	envsubst $(ENVSUBST_VARS) < config/k3s.yml.tpl > /tmp/registries.yaml
	sudo mv /tmp/registries.yaml /etc/rancher/k3s/registries.yaml
	sudo systemctl restart k3s

system:
	@echo "Configuring system"
	# Set inotify limits (required for k8s)
	# Persist via sysctl.d so they survive reboots (especially on immutable distros)
	sudo sysctl fs.inotify.max_user_instances=8192
	sudo sysctl fs.inotify.max_user_watches=524288
	@echo "fs.inotify.max_user_instances=8192" | sudo tee /etc/sysctl.d/99-lagoon.conf > /dev/null
	@echo "fs.inotify.max_user_watches=524288" | sudo tee -a /etc/sysctl.d/99-lagoon.conf > /dev/null
	# Install NFS support
	@if [ -f /run/ostree-booted ]; then \
		echo "Immutable OS detected (ostree/atomic)"; \
		if ! rpm -q nfs-utils >/dev/null 2>&1; then \
			echo "Installing nfs-utils via rpm-ostree (reboot required after install)"; \
			sudo rpm-ostree install -y --allow-inactive nfs-utils; \
			echo "NOTE: You may need to reboot for NFS support to take effect."; \
		else \
			echo "nfs-utils already available"; \
		fi; \
	elif command -v apt-get >/dev/null 2>&1; then \
		sudo apt-get update && sudo apt-get install -y nfs-common; \
	elif command -v dnf >/dev/null 2>&1; then \
		sudo dnf install -y nfs-utils; \
	elif command -v yum >/dev/null 2>&1; then \
		sudo yum install -y nfs-utils; \
	elif command -v pacman >/dev/null 2>&1; then \
		sudo pacman -S --noconfirm nfs-utils; \
	else \
		echo "Warning: Could not detect package manager. Install NFS client manually."; \
	fi

helm-repos: helm
	@echo "Adding helm repos"
	helm repo add harbor https://helm.goharbor.io
	helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx
	helm repo add stable https://charts.helm.sh/stable
	# Note: PostgreSQL and MariaDB use cloudpirates OCI charts (no repo needed)
	helm repo add amazeeio https://amazeeio.github.io/charts/
	helm repo add lagoon https://uselagoon.github.io/lagoon-charts/
	helm repo add minio https://charts.min.io/
	helm repo add nats https://nats-io.github.io/k8s/helm/charts/
	helm repo add metallb https://metallb.github.io/metallb
	helm repo add jetstack https://charts.jetstack.io
	helm repo add jouve https://jouve.github.io/charts/
	helm repo add twuni https://twuni.github.io/docker-registry.helm
	helm repo add k8up https://k8up-io.github.io/k8up
	helm repo add appuio https://charts.appuio.ch
	helm repo add prometheus-community https://prometheus-community.github.io/helm-charts
	helm repo add headlamp https://kubernetes-sigs.github.io/headlamp/
	helm repo add gatekeeper https://open-policy-agent.github.io/gatekeeper/charts
	helm repo update

metallb:
	@echo "Installing MetalLB"
	helm upgrade \
		--install \
		--create-namespace \
		--namespace metallb-system \
		--wait \
		metallb \
		metallb/metallb
	envsubst $(ENVSUBST_VARS) < config/metallb.yml.tpl > build/metallb.yml
	kubectl apply -f build/metallb.yml

cert-manager:
	@echo "Installing cert-manager"
	helm upgrade \
		--install \
		--create-namespace \
		--namespace cert-manager \
		--wait \
		-f build/values/cert-manager.yml \
		cert-manager \
		jetstack/cert-manager
	# Generate self-signed CA if using self-signed mode
	@if [ "$(TLS_MODE)" = "selfsigned" ]; then \
		mkdir -p certs; \
		if ! openssl x509 -enddate -noout -in certs/rootCA.pem > /dev/null 2>&1; then \
			echo "Generating self-signed root CA"; \
			openssl genrsa -out certs/rootCA-key.pem 2048; \
			openssl req -x509 -new -nodes -key certs/rootCA-key.pem \
				-sha256 -days 3560 -out certs/rootCA.pem \
				-addext keyUsage=critical,digitalSignature,keyEncipherment,keyCertSign \
				-subj '/CN=lagoon.test'; \
		fi; \
		kubectl -n cert-manager create secret generic lagoon-secret \
			--from-file=tls.crt=certs/rootCA.pem \
			--from-file=tls.key=certs/rootCA-key.pem \
			--from-file=ca.crt=certs/rootCA.pem \
			--dry-run=client -o yaml | kubectl apply -f -; \
	fi
	# Apply cluster issuers based on TLS mode
	kubectl apply -f build/config/lagoon-issuer-selfsigned.yml
	@if [ "$(TLS_MODE)" = "letsencrypt" ] || [ "$(TLS_MODE)" = "cloudflare" ]; then \
		kubectl apply -f build/config/lagoon-issuer-letsencrypt.yml; \
		kubectl apply -f build/config/lagoon-issuer-letsencrypt-staging.yml; \
	fi
	@if [ "$(TLS_MODE)" = "cloudflare" ]; then \
		kubectl apply -f build/config/lagoon-issuer-cloudflare.yml; \
	fi
	# Install trust-manager for CA distribution
	helm upgrade \
		--install \
		--create-namespace \
		--namespace cert-manager \
		--wait \
		--version=v0.19.0 \
		--set crds.enabled=true \
		--set secretTargets.enabled=true \
		--set secretTargets.authorizedSecretsAll=true \
		trust-manager \
		jetstack/trust-manager
	kubectl apply -f config/ca-bundle.yml

gatekeeper:
	@echo "Installing Gatekeeper"
	helm upgrade \
		--install \
		--create-namespace \
		--namespace gatekeeper-system \
		--wait \
		--version=v3.11.0 \
		--set replicas=1 \
		gatekeeper \
		gatekeeper/gatekeeper
	kubectl apply -f config/ca-volume.yml


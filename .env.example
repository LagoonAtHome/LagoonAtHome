# LagoonAtHome Configuration
# Copy to .env and modify, or run ./install.sh to generate interactively.

# --- Network ---
NODE_IP=192.168.1.150
LAGOON_NETWORK_RANGE=192.168.1.150-192.168.1.160

# --- TLS ---
# Options: selfsigned | letsencrypt | cloudflare
TLS_MODE=selfsigned
# Required for letsencrypt and cloudflare modes:
ACME_EMAIL=
# Required for cloudflare mode only:
CLOUDFLARE_API_TOKEN=

# --- Domain ---
# For selfsigned: auto-derived as ${NODE_IP}.nip.io
# For letsencrypt/cloudflare: your real domain (e.g., lagoon.example.com)
DOMAIN=192.168.1.150.nip.io

# Derived from TLS_MODE (selfsigned=lagoon-issuer, letsencrypt=letsencrypt-prod, cloudflare=cloudflare-dns01)
CLUSTER_ISSUER=lagoon-issuer

# --- Admin User ---
ADMIN_EMAIL=admin@example.com
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_PASSWORD=changeme
ORG_NAME=lagoon
SSH_KEY_PATH=~/.ssh/id_ed25519

# --- Service Passwords (generate random values for production) ---
MINIO_PASSWORD=changeme
HARBOR_PASSWORD=changeme
POSTGRES_PASSWORD=changeme
MARIADB_PASSWORD=changeme

# --- Optional Components (true/false) ---
INSTALL_HARBOR=false
INSTALL_PROMETHEUS=false
INSTALL_POSTGRES=true
INSTALL_MARIADB=true
INSTALL_HEADLAMP=false
